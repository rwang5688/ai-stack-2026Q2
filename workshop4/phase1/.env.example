# REQUIRED: Your SageMaker XGBoost Serverless Endpoint name
# (Deploy this separately before running populate_seed_data.py)
XGBOOST_ENDPOINT_NAME=<PASTE-YOUR-ENDPOINT-NAME-HERE>


{
  "name": "studentservices",
  "version": 1,
  "managedBy": "CDK",
  "tags": {
    "agentcore:created-by": "agentcore-cli",
    "agentcore:project-name": "studentservices"
  },
  "runtimes": [
    {
      "name": "StudentServicesAgent",
      "build": "CodeZip",
      "entrypoint": "agent.py",
      "codeLocation": "./student_services/",
      "runtimeVersion": "PYTHON_3_13",
      "envVars": [{"name": "PYTHONIOENCODING", "value": "utf-8"}],
      "networkMode": "PUBLIC",
      "protocol": "HTTP"
    },
    {
      "name": "CourseRegistrationMcp",
      "build": "CodeZip",
      "entrypoint": "agent.py",
      "codeLocation": "./course_registration/",
      "runtimeVersion": "PYTHON_3_13",
      "envVars": [{"name": "MCP_TRANSPORT", "value": "streamable-http"}, {"name": "PYTHONIOENCODING", "value": "utf-8"}],
      "networkMode": "PUBLIC",
      "protocol": "MCP",
      "authorizerType": "CUSTOM_JWT",
      "authorizerConfiguration": {
        "customJwtAuthorizer": {
          "discoveryUrl": "PLACEHOLDER_AFTER_CFN_DEPLOY",
          "allowedClients": ["PLACEHOLDER_AFTER_CFN_DEPLOY"],
          "allowedScopes": ["course-registration/access"]
        }
      }
    },
    {
      "name": "CourseReviewMcp",
      "build": "CodeZip",
      "entrypoint": "agent.py",
      "codeLocation": "./course_review/",
      "runtimeVersion": "PYTHON_3_13",
      "envVars": [{"name": "MCP_TRANSPORT", "value": "streamable-http"}, {"name": "PYTHONIOENCODING", "value": "utf-8"}],
      "networkMode": "PUBLIC",
      "protocol": "MCP",
      "authorizerType": "CUSTOM_JWT",
      "authorizerConfiguration": {
        "customJwtAuthorizer": {
          "discoveryUrl": "PLACEHOLDER_AFTER_CFN_DEPLOY",
          "allowedClients": ["PLACEHOLDER_AFTER_CFN_DEPLOY"],
          "allowedScopes": ["course-review/access"]
        }
      }
    },
    {
      "name": "LoanApplicationMcp",
      "build": "CodeZip",
      "entrypoint": "agent.py",
      "codeLocation": "./loan_application/",
      "runtimeVersion": "PYTHON_3_13",
      "envVars": [{"name": "MCP_TRANSPORT", "value": "streamable-http"}, {"name": "PYTHONIOENCODING", "value": "utf-8"}],
      "networkMode": "PUBLIC",
      "protocol": "MCP",
      "authorizerType": "CUSTOM_JWT",
      "authorizerConfiguration": {
        "customJwtAuthorizer": {
          "discoveryUrl": "PLACEHOLDER_AFTER_CFN_DEPLOY",
          "allowedClients": ["PLACEHOLDER_AFTER_CFN_DEPLOY"],
          "allowedScopes": ["loan-application/access"]
        }
      }
    },
    {
      "name": "MathTeachingMcp",
      "build": "CodeZip",
      "entrypoint": "agent.py",
      "codeLocation": "./math_teaching/",
      "runtimeVersion": "PYTHON_3_13",
      "envVars": [{"name": "MCP_TRANSPORT", "value": "streamable-http"}, {"name": "PYTHONIOENCODING", "value": "utf-8"}],
      "networkMode": "PUBLIC",
      "protocol": "MCP",
      "authorizerType": "CUSTOM_JWT",
      "authorizerConfiguration": {
        "customJwtAuthorizer": {
          "discoveryUrl": "PLACEHOLDER_AFTER_CFN_DEPLOY",
          "allowedClients": ["PLACEHOLDER_AFTER_CFN_DEPLOY"],
          "allowedScopes": ["math-teaching/access"]
        }
      }
    }
  ],
  "memories": [
    {
      "name": "StudentServicesMemory",
      "eventExpiryDuration": 30,
      "strategies": [
        {"type": "SEMANTIC", "namespaces": ["/users/{actorId}/facts"]},
        {"type": "SUMMARIZATION", "namespaces": ["/summaries/{actorId}/{sessionId}"]},
        {"type": "USER_PREFERENCE", "namespaces": ["/users/{actorId}/preferences"]}
      ]
    }
  ],
  "credentials": [
    {"authorizerType": "OAuthCredentialProvider", "name": "CourseRegistrationMcp-oauth", "discoveryUrl": "PLACEHOLDER_AFTER_CFN_DEPLOY", "scopes": ["course-registration/access"], "vendor": "CustomOauth2"},
    {"authorizerType": "OAuthCredentialProvider", "name": "CourseReviewMcp-oauth", "discoveryUrl": "PLACEHOLDER_AFTER_CFN_DEPLOY", "scopes": ["course-review/access"], "vendor": "CustomOauth2"},
    {"authorizerType": "OAuthCredentialProvider", "name": "LoanApplicationMcp-oauth", "discoveryUrl": "PLACEHOLDER_AFTER_CFN_DEPLOY", "scopes": ["loan-application/access"], "vendor": "CustomOauth2"},
    {"authorizerType": "OAuthCredentialProvider", "name": "MathTeachingMcp-oauth", "discoveryUrl": "PLACEHOLDER_AFTER_CFN_DEPLOY", "scopes": ["math-teaching/access"], "vendor": "CustomOauth2"},
    {"authorizerType": "OAuthCredentialProvider", "name": "StudentServicesGateway-oauth", "discoveryUrl": "PLACEHOLDER_AFTER_CFN_DEPLOY", "scopes": ["student-services-gateway/access"], "vendor": "CustomOauth2"}
  ],
  "evaluators": [],
  "onlineEvalConfigs": [],
  "agentCoreGateways": [],
  "policyEngines": []
}
                    "outboundAuth": {
                        "type": "OAUTH",
                        "credentialName": "LoanApplicationMcp-oauth"
                    },
                    "toolDefinitions": [
                        {
                            "name": "predict_loan",
                            "description": "Predict loan acceptance based on features",
                            "inputSchema": {
                                "type": "object"
                            }
                        }
                    ]

                    ]
                }
            },
            "name": "studentservicesgateway",
            "description": "Gateway aggregating all Student Services specialist MCP servers",
            "targets": [
                {
                    "name": "coursecatalog",
                    "targetType": "mcpServer",
                    "endpoint": "https://bedrock-agentcore.us-west-2.amazonaws.com/runtimes/arn%3Aaws%3Abedrock-agentcore%3Aus-west-2%3A149057604171%3Aruntime%2Fstudentservices_CourseCatalogMcp-fulwsf32ho/invocations",
                    "outboundAuth": {
                        "type": "OAUTH",
                        "credentialName": "CourseCatalogMcp-oauth"
                    },
                    "toolDefinitions": [
                        {
                            "name": "search_course_catalog",
                            "description": "Search the course catalog knowledge base",
                            "inputSchema": {
                                "type": "object"
                            }
                        }
                    ]
                },
                {
                    "name": "coursereviews",
                    "targetType": "mcpServer",
                    "endpoint": "https://bedrock-agentcore.us-west-2.amazonaws.com/runtimes/arn%3Aaws%3Abedrock-agentcore%3Aus-west-2%3A149057604171%3Aruntime%2Fstudentservices_CourseReviewsMcp-GtfbiG65pV/invocations",
                    "outboundAuth": {
                        "type": "OAUTH",
                        "credentialName": "CourseReviewsMcp-oauth"
                    },
                    "toolDefinitions": [
                        {
                            "name": "get_course_reviews",
                            "description": "Get student reviews for a course from DynamoDB",
                            "inputSchema": {
                                "type": "object"
                            }
                        }
                    ]
                },
                {
                    "name": "courseregistration",
                    "targetType": "mcpServer",
                    "endpoint": "https://bedrock-agentcore.us-west-2.amazonaws.com/runtimes/arn%3Aaws%3Abedrock-agentcore%3Aus-west-2%3A149057604171%3Aruntime%2Fstudentservices_CourseRegistrationMcp-8zewrkF29n/invocations",
                    "outboundAuth": {
                        "type": "OAUTH",
                        "credentialName": "CourseRegistrationMcp-oauth"
                    },
                    "toolDefinitions": [
                        {
                            "name": "register_course",
                            "description": "Register a student in a course",
                            "inputSchema": {
                                "type": "object"
                            }
                        }
                    ]
                },
                {
                    "name": "loanapplication",
                    "targetType": "mcpServer",

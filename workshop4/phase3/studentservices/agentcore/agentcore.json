    "memories": [
        {
            "name": "StudentServicesMemory",
            "eventExpiryDuration": 30,
            "strategies": [
                {
                    "type": "SEMANTIC",
                    "namespaces": [
                        "/users/{actorId}/facts"
                    ]
                },
                {
                    "type": "SUMMARIZATION",
                    "namespaces": [
                        "/summaries/{actorId}/{sessionId}"
                    ]
                },
                {
                    "type": "USER_PREFERENCE",
                    "namespaces": [
                        "/users/{actorId}/preferences"
                    ]
                }
            ]
        }
    ],
